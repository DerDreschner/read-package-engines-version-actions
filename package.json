{
  "name": "@skjnldsv/read-package-engines-version-actions",
  "description": "Output node and npm version numbers from package.json",
  "private": true,
  "main": "lib/main.js",
  "scripts": {
    "lint": "eslint src/*.ts src/**/*.ts",
    "lint:fix": "eslint --fix src/*.ts src/**/*.ts",
    "build": "tsc",
    "build:watch": "tsc -w",
    "package": "ncc build --source-map --license licenses.txt",
    "test": "jest",
    "prettier": "prettier --check src/*.ts src/**/*.ts",
    "prettier:fix": "prettier --write src/*.ts src/**/*.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/skjnldsv/read-package-engines-version-actions.git"
  },
  "keywords": [
    "actions",
    "node",
    "setup"
  ],
  "author": "skjnldsv",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.11.1"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "@vercel/ncc": "^0.38.4",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "jest": "^30.4.2",
    "jest-circus": "^30.4.2",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "ts-jest": "^29.4.11",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": "^20.0.0",
    "npm": "^10.0.0"
  }
}
