{
  "name": "@skjnldsv/read-package-engines-version-actions",
  "description": "Output node and npm version numbers from package.json",
  "private": true,
  "type": "module",
  "main": "lib/main.js",
  "scripts": {
    "lint": "eslint src/*.ts src/**/*.ts",
    "lint:fix": "eslint --fix src/*.ts src/**/*.ts",
    "build": "tsc",
    "build:watch": "tsc -w",
    "package": "ncc build --source-map --license licenses.txt",
    "test": "jest",
    "prettier": "prettier --check src/*.ts src/**/*.ts",
    "prettier:fix": "prettier --write src/*.ts src/**/*.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/skjnldsv/read-package-engines-version-actions.git"
  },
  "keywords": [
    "actions",
    "node",
    "setup"
  ],
  "author": "skjnldsv",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^3.0.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@tsconfig/node24": "^24.0.4",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "@vercel/ncc": "^0.44.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.6.0",
    "jest": "^30.4.2",
    "jest-circus": "^30.4.2",
    "jiti": "^2.7.0",
    "lint-staged": "^17.0.8",
    "prettier": "^3.8.4",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  },
  "engines": {
    "node": "^24.0.0",
    "npm": "^11.0.0"
  }
}
